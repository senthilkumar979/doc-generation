# Copy to `.env.local` for local development.

# Supabase — Project Settings → API (Connect). Never use the service_role key in NEXT_PUBLIC_* or client code.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Recommended: publishable key (sb_publishable_…). Same role as the legacy anon key for the browser client.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Legacy (still supported until Supabase retires it): JWT anon key from “Legacy API Keys” if you do not use publishable keys yet.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt_here

# Server-side only — never expose in client bundles or release notes.
# Enables Supabase lookups for `/api/v1` Bearer API keys and `api_usage_logs` inserts.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
